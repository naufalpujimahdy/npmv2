{
  "name": "npmv2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev:frontend": "pnpm --dir apps/frontend dev",
    "dev:backend": "pnpm --dir apps/backend dev",
    "build:frontend": "pnpm --dir apps/frontend build",
    "build:backend": "pnpm --dir apps/backend build",
    "lint:frontend": "pnpm --dir apps/frontend lint",
    "lint:backend": "pnpm --dir apps/backend lint",
    "seed": "pnpm --dir apps/backend seed"
  }
}
