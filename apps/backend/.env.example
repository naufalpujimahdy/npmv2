# Database Configuration
# For local MySQL: mysql://root:password@localhost:3306/npmv2
# For remote MySQL: mysql://user:pass@host:3306/database_name
DATABASE_URL=mysql://root:@localhost:3306/npmv2

# JWT Configuration
# Use a strong random string for production (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-secure-key-min-32-chars

# Frontend URL for CORS
# In production, set to your actual frontend domain
FRONTEND_URL=http://localhost:3001

# Optional: Admin API Key for protected admin endpoints
ADMIN_API_KEY=<your_admin_api_key>

# Node Environment
NODE_ENV=development

