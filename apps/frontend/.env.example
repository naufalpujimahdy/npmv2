# Backend API URL
# For local development, use http://localhost:3000
# For production, use your actual backend domain
NEXT_PUBLIC_API_URL=http://localhost:3000

# Admin API Key — must match ADMIN_API_KEY in backend .env
# Sent as x-api-key header on every CMS request
NEXT_PUBLIC_API_KEY=change-me-to-a-strong-random-key
